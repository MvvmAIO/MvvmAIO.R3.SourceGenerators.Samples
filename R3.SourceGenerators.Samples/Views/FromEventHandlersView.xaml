<UserControl x:Class="R3.SourceGenerators.Samples.Views.FromEventHandlersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="420" d:DesignWidth="640">
    <DockPanel LastChildFill="True">
        <ScrollViewer DockPanel.Dock="Top" Margin="0,0,0,12" VerticalScrollBarVisibility="Auto" MaxHeight="180">
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="CLR EventHandler-style" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#E0FFFFFF"/>
                <TextBlock TextWrapping="Wrap"
                           Foreground="#99FFFFFF"
                           FontSize="12"
                           Margin="0,0,0,10"
                           Text="EventHandler*: Observable.FromEventHandler. Custom delegates like delegate void Foo(object sender, T e) use Observable.FromEvent internally and still expose Observable&lt;(object? sender, T e)&gt; on the wrapper. EventHandler&lt;string?&gt; maps to (object?, string?)."/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="CounterPulse (EventHandler)" Padding="14,8" Margin="0,0,8,0"
                            Command="{Binding RaiseCounterPulseCommand}" />
                    <Button Content="PayloadChanged (value)" Padding="14,8" Margin="0,0,8,0"
                            Command="{Binding RaisePayloadValueCommand}" />
                    <Button Content="PayloadChanged (null)" Padding="14,8" Margin="0,0,8,0"
                            Command="{Binding RaisePayloadNullCommand}" />
                    <Button Content="Custom delegate (object,string)" Padding="14,8" Margin="0,0,8,0"
                            Command="{Binding RaiseCustomDelegateCommand}" />
                    <Button Content="Clear log" Padding="14,8" Command="{Binding ClearLogCommand}" />
                </StackPanel>
                <TextBlock Text="DispatcherTimer.Tick (EventHandler)" FontWeight="SemiBold" Margin="0,12,0,6" Foreground="#E0FFFFFF"/>
                <TextBlock TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="#99FFFFFF"
                           Margin="0,0,0,8"
                           Text="The timer is a Framework element–adjacent DispatcherTimer; codegen discovers FromEventHandlers() on the receiver and emits a Tick observable."/>
                <Button Content="{Binding TimerToggleLabel}" Padding="14,8" HorizontalAlignment="Left"
                        Command="{Binding ToggleTimerCommand}" />
            </StackPanel>
        </ScrollViewer>
        <TextBox Text="{Binding Log, Mode=OneWay}"
                 Foreground="#FFF1F1F1"
                 CaretBrush="#FFF1F1F1"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="12"
                 Background="#14000000"
                 BorderBrush="#33FFFFFF"/>
    </DockPanel>
</UserControl>
